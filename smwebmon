#!/usr/bin/env python3
"""smwebmon launcher — mirrors ./smtop's source-tree path trick.

When run from the source tree (./smwebmon), makes the sibling
smartmet_top and smartmet_webmon packages importable. When the RPM
installs to /usr/bin/smwebmon, the packages live on Python's default
path so the sys.path insertion below is a harmless no-op.
"""

import os
import sys

here = os.path.dirname(os.path.realpath(__file__))
if (os.path.isdir(os.path.join(here, "smartmet_webmon"))
        and here not in sys.path):
    sys.path.insert(0, here)

from smartmet_webmon.__main__ import main

if __name__ == "__main__":
    sys.exit(main())
