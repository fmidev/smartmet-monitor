#!/bin/bash
# bwho — top productions by the injected who= query parameter in the SmartMet access log.

set -o pipefail

LIB="${SMARTMET_MONITOR_LIB:-/usr/share/smartmet/bstat.sh}"
if [ ! -r "$LIB" ]; then
    here=$(cd "$(dirname "$(readlink -f "$0")")" && pwd)
    if [ -r "$here/../share/smartmet/bstat.sh" ]; then
        LIB="$here/../share/smartmet/bstat.sh"
    fi
fi

if [ ! -r "$LIB" ]; then
    echo "bwho: library not found at $LIB" >&2
    exit 1
fi

# shellcheck source=/usr/share/smartmet/bstat.sh
. "$LIB"
bwho "$@"
